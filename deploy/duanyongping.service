[Unit]
Description=Duan Yongping Explorer
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/duanyongping
Environment="PYTHONUNBUFFERED=1"
ExecStart=/var/www/duanyongping/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
